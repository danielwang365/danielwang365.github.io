---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="container">
      <slot />

      <p class="list">&copy; Daniel Wang <script>document.write(new Date().getFullYear())</script></p>
    </div>

    <style>
      @import '../styles/global.css';
    </style>
  </body>
</html>
